# spotiflac-pipeline configuration
#
# Copy this file to ~/.config/spotiflac-pipeline/spotiflac.env and edit.
# Every key has a sane default (shown below as the commented-out value);
# uncomment a line only to override that default.
#
# All scripts in bin/ read this file at startup. The file is shell-sourceable
# AND parsed by the Python scripts at top of file (no PyYAML dependency).

# ─── core paths ──────────────────────────────────────────────────────────────

# Root under which the pipeline reads/writes music. Tracks downloaded by
# spotiflac end up under $SPOTIFLAC_OUTPUT_DIR/_library/<Artist>/<Album>/…
#SPOTIFLAC_MUSIC_ROOT="$HOME/Music"

# Where spotiflac downloads (overrides MUSIC_ROOT-derived default).
# The pipeline creates and manages _library/ and _playlists/ inside this dir.
#SPOTIFLAC_OUTPUT_DIR="$SPOTIFLAC_MUSIC_ROOT/spotiflac"

# Optional: directory that holds your old spotdl downloads (MP3s).
# Layout the pipeline expects: $SPOTDL_ROOT/liked/<Artist> - <Title>.mp3
# and $SPOTDL_ROOT/playlists/<PlaylistName>/<Artist> - <Title>.mp3
# Leave unset if you don't have a spotdl collection — the audit/redownload/
# dedup scripts will simply find nothing to do.
#SPOTIFLAC_SPOTDL_ROOT="$SPOTIFLAC_MUSIC_ROOT/spotdl"

# State + log files (small JSON/txt; never holds music).
#SPOTIFLAC_STATE_DIR="$HOME/.local/state/spotiflac-pipeline"

# Python virtualenv with spotiflac + yt-dlp installed. install.sh creates this.
#SPOTIFLAC_VENV="$HOME/.local/share/spotiflac-pipeline/venv"

# ─── notifications (optional) ────────────────────────────────────────────────

# Telegram bot for batch start/end + warning alerts. Leave empty to disable.
#SPOTIFLAC_TELEGRAM_BOT_TOKEN=""
#SPOTIFLAC_TELEGRAM_CHAT_ID=""

# ─── watchdog coordination (optional) ────────────────────────────────────────

# If set and mounted, the watchdog will defer execution while this path is a
# mountpoint (useful to avoid contending with an external backup).
#SPOTIFLAC_BACKUP_MOUNTPOINT=""

# Comma-separated list of process names whose presence makes the watchdog
# defer. Example: "rsync,backup_external.sh,spotdl/spotify-downloader"
#SPOTIFLAC_BACKUP_PROCNAMES=""

# Thresholds below which the watchdog refuses to start a batch and emits a
# warning.
#SPOTIFLAC_MIN_FREE_DISK_GB=50
#SPOTIFLAC_MIN_FREE_MEM_MB=200

# ─── provider rotation (advanced) ────────────────────────────────────────────

# Comma-separated provider chains the watchdog rotates through when a chain
# stops making progress. Each chain is a space-separated list of providers
# spotiflac understands: deezer, tidal, amazon, qobuz, soundcloud, youtube,
# spoti, apple. Leftmost provider is tried first per track.
#
# Default order rationale (see CHANGELOG 2026-06-03): Deezer maps Spotify→ISRC
# →Deezer (correct by construction), so it leads every chain. Tidal/Amazon
# stay available as fallbacks. The final "deezer youtube" chain is misroute-
# proof — accept lossy M4A over wrong audio.
#SPOTIFLAC_PROVIDER_CHAINS="deezer tidal amazon youtube,deezer amazon tidal youtube,deezer tidal amazon,deezer youtube"

# ─── playlists.json enrichment (optional) ────────────────────────────────────

# Path to an old spotdl playlist export (JSON). Used by migrate-to-flat.py and
# dedup-tracks.py to enrich track-ID sets for playlists larger than the
# Spotify embed cap of 100 tracks. Leave unset if you don't have one.
#SPOTIFLAC_OLD_PLAYLISTS_JSON=""

# Names of playlists in the old export that should be merged together with
# any "Liked Songs" / "TRACKS MM/YY" snapshots, treated as one logical
# "Likes" proxy playlist. Comma-separated.
#SPOTIFLAC_LIKES_ALIASES="Liked Songs"
